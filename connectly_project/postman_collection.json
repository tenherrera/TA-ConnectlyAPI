{
  "info": {
    "name": "Connectly - RBAC & Privacy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "ownerToken",
      "value": ""
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "publicPostId",
      "value": ""
    },
    {
      "key": "privatePostId",
      "value": ""
    },
    {
      "key": "commentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Admin User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"postman_admin\",\n  \"email\": \"postman_admin@test.com\",\n  \"password\": \"adminpass123\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/users/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "users",
            ""
          ]
        }
      },
      "response": []
    },
