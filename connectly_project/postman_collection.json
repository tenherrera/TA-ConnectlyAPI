    {
      "name": "Create Public Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Public post created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data.post_id) {",
              "    pm.collectionVariables.set('publicPostId', data.post_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{ownerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"post_type\": \"text\",\n  \"title\": \"Owner Public Post\",\n  \"content\": \"Everyone should see this\",\n  \"privacy\": \"public\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/factory/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "factory",
            ""
          ]
        }
      },
      "response": []
    },
