{
  "info": {
    "name": "Connectly - Likes & Comments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login (get token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"smoketest\",\n  \"password\": \"password\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/login/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "login",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/posts/posts/10/like/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "10",
            "like",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Comment on Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This is a Postman test comment\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/posts/10/comment/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "10",
            "comment",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Post Comments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/posts/posts/10/comments/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "10",
            "comments",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "[EDGE CASE] Like Post Multiple Times",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/posts/posts/10/like/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "10",
            "like",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "[EDGE CASE] Comment on Non-Existent Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This should fail - post doesn't exist\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/posts/99999/comment/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "99999",
            "comment",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "[EDGE CASE] Get Comments from Non-Existent Post",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Token {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/posts/posts/99999/comments/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "99999",
            "comments",
            ""
          ]
        }
      },
      "response": []
    }
  ]
}
