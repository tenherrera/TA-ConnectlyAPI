          },
          {
            "key": "Authorization",
            "value": "Token {{userToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This comment will be used for admin delete testing\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/posts/{{publicPostId}}/comment/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "posts",
            "{{publicPostId}}",
            "comment",
            ""
          ]
        }
