    {
      "name": "Comment On Public Post As Regular User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Comment created on public post', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data.id) {",
              "    pm.collectionVariables.set('commentId', data.id);",
