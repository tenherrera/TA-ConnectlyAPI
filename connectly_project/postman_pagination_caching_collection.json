{
  "info": {
    "name": "Connectly - Pagination & Caching",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "ownerToken",
      "value": ""
    },
    {
      "key": "latestCreatedPostId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login Owner For Caching Demo",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Owner login succeeded', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data.token) {",
              "    pm.collectionVariables.set('ownerToken', data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"postman_owner\",\n  \"password\": \"ownerpass123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/login/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "login",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed Page 1",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=1&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed Page 2",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=2&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed Invalid Page",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=99&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "99"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed Cache Test 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Feed request succeeded', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('First request is a cache miss', function () {",
              "    pm.expect(pm.response.headers.get('X-Cache')).to.eql('MISS');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=1&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed Cache Test 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Feed request succeeded', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Second request is a cache hit', function () {",
              "    pm.expect(pm.response.headers.get('X-Cache')).to.eql('HIT');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=1&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Post To Invalidate Cache",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Post created for cache invalidation', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data.post_id) {",
              "    pm.collectionVariables.set('latestCreatedPostId', data.post_id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Token {{ownerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"post_type\": \"text\",\n  \"title\": \"Cache Invalidation Demo Post\",\n  \"content\": \"This post forces feed cache invalidation\",\n  \"privacy\": \"public\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts/factory/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "factory",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Feed After Cache Invalidation",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Feed request after invalidation succeeded', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Feed is repopulated after invalidation', function () {",
              "    pm.expect(pm.response.headers.get('X-Cache')).to.eql('MISS');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/feed/?page=1&page_size=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "posts",
            "feed",
            ""
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "page_size",
              "value": "2"
            }
          ]
        }
      },
      "response": []
    }
  ]
}
